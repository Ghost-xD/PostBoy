{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Ripple",
  "version": "0.0.1",
  "identifier": "com.ripple.app",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../build"
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "deb",
      "appimage",
      "dmg",
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "createUpdaterArtifacts": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ripple",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "maximized": true,
        "center": true,
        "visible": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Ghost-xD/PostBoy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEyMDY5QjkwQ0M3QTMwODEKUldTQk1Ick1rSnNHRWhqeEo2c2RSb2h0NldwZi8vOWxEZnMvWkxTaTFlWmNZeHZyQWUrVmROeWgK",
      "dangerousInsecureTransportProtocol": true
    }
  }
}
